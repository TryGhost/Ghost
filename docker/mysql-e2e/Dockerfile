# Pre-seeded MySQL image for the E2E suite.
#
# Identical to the stock mysql image plus a baked, already-initialized data dir.
# The E2E stack runs MySQL on tmpfs (empty every run), which normally forces the
# stock image to re-run first-boot initialization each time; seed-entrypoint.sh
# copies the baked data dir into the empty tmpfs so mysqld skips init and is ready
# in ~1s instead of several. The seed is ~200MB uncompressed but almost entirely
# sparse InnoDB files, so it adds only ~4MB to the compressed pull.
#
# The seed must be produced from the SAME base image (docker/mysql-e2e/generate-seed.sh
# reads it from compose.dev.yaml); MYSQL_IMAGE is passed as a build-arg to keep them
# in lockstep.

ARG MYSQL_IMAGE
FROM ${MYSQL_IMAGE}

# Generated by docker/mysql-e2e/generate-seed.sh (not committed; built in CI).
COPY seed /var/lib/mysql-seed
COPY seed-entrypoint.sh /usr/local/bin/seed-entrypoint.sh
RUN chmod +x /usr/local/bin/seed-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/seed-entrypoint.sh"]
CMD ["mysqld"]
