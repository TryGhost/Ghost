{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/.npmrc",
      "{workspaceRoot}/ghost/tsconfig.json",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/pnpm-workspace.yaml",
      "{workspaceRoot}/pnpm-lock.yaml"
    ]
  },
  "parallel": 4,
  "useDaemonProcess": false,
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        {
          "env": "GHOST_CDN_URL"
        },
        "default",
        "^default"
      ],
      "outputs": [
        "{projectRoot}/build",
        "{projectRoot}/dist",
        "{projectRoot}/es",
        "{projectRoot}/types",
        "{projectRoot}/umd"
      ],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "test": {
      "cache": true
    },
    "test:unit": {
      "cache": true,
      "dependsOn": [
        "build"
      ]
    },
    "test:ci:*": {
      "cache": true,
      "inputs": [
        "default",
        "^default",
        {
          "env": "DB"
        },
        {
          "env": "NODE_ENV"
        }
      ]
    },
    "dev": {
      "dependsOn": [
        "^dev"
      ],
      "continuous": true
    }
  },
  "cacheDirectory": ".nxcache",
  "analytics": true,
  "nxCloudId": "6a146249a88a39d9ffa5046c"
}
