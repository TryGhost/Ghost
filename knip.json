{
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "ignoreWorkspaces": [
        "ghost/admin"
    ],
    "ignore": [
        "ghost/core/test/utils/fixtures/themes/**/assets/built/**"
    ],
    "workspaces": {
        ".": {
            "vitest": {
                "config": []
            },
            "ignoreDependencies": [
                "@vitejs/plugin-react",
                "vite-plugin-svgr"
            ]
        },
        "ghost/core": {
            "ignoreDependencies": [
                "@slack/webhook",
                "superagent",
                "superagent-throttle",
                "bookshelf-relations"
            ]
        },
        "apps/admin": {
            "ignoreDependencies": [
                "@tryghost/kg-unsplash-selector"
            ]
        },
        "apps/announcement-bar": {
            "ignoreDependencies": [
                "@vitejs/plugin-react",
                "vite-plugin-svgr"
            ]
        },
        "apps/comments-ui": {
            "ignoreDependencies": [
                "@tryghost/debug",
                "@vitejs/plugin-react",
                "vite-plugin-svgr"
            ]
        },
        "apps/portal": {
            "ignoreDependencies": [
                "@tryghost/debug",
                "@vitejs/plugin-react",
                "vite-plugin-svgr"
            ]
        },
        "apps/signup-form": {
            "ignoreDependencies": [
                "@tryghost/debug",
                "@vitejs/plugin-react",
                "vite-plugin-svgr"
            ]
        },
        "apps/sodo-search": {
            "ignoreDependencies": [
                "@tryghost/debug",
                "@vitejs/plugin-react",
                "vite-plugin-svgr"
            ]
        }
    }
}
