  "nx": {
    "targets": {
      "build:tsc": {
        "dependsOn": [
          "^build"
        ]
      },
      "archive": {
        "dependsOn": [
          "build:assets",
          "build:tsc",
          {
            "projects": [
              "@tryghost/admin"
            ],
            "target": "build"
          }
        ]
      },
      "dev": {
        "dependsOn": [
          "build:assets"
        ]
      },
      "lint": {
        "dependsOn": [
          "^build"
        ]
      },
      "test:all": {
        "dependsOn": [
          "build:assets"
        ]
      },
      "test:unit": {
        "dependsOn": [
          "build:assets",
          "^build"
        ]
      },
      "test:ci:e2e": {
        "dependsOn": [
          "^build"
        ]
      },
      "test:ci:legacy": {
        "dependsOn": [
