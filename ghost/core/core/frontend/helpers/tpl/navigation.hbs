<ul class="nav">
    {{#foreach navigation}}
    <li class="{{link_class for=(url) class=(concat "nav-" slug)}}"><a href="{{url absolute="true"}}">{{#if icon}}<img class="nav-icon" src="{{icon}}" alt="{{iconAlt}}">{{/if}}{{#if label}}<span class="nav-label">{{label}}</span>{{/if}}</a></li>
    {{/foreach}}
</ul>
