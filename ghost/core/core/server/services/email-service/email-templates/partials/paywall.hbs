<div class="kg-paywall align-center">
    <table class="kg-paywall-hr" role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0">
        <tbody>
            <tr>
                <td>
                    <!--[if !mso]><!-- -->
                    <hr style="display: none;" />
                    <!--<![endif]-->
                    <table class="kg-hr" role="presentation" border="0" cellpadding="0" cellspacing="0">
                        <tbody>
                            <tr>
                                <td>&nbsp;</td>
                            </tr>
                        </tbody>
                    </table>
                </td>
            </tr>
        </tbody>
    </table>
    {{#if paywall.heading}}
    <h3>{{paywall.heading}}</h3>
    {{else}}
    <h3>{{t 'Upgrade to continue reading.'}}</h3>
    {{/if}}
    {{#if paywall.description}}
    <p>{{paywall.description}}</p>
    {{else}}
    {{#unless paywall.heading}}
    {{! only the fully-default paywall keeps the built-in supporting line —
        once any custom copy is in play, a blank description renders blank,
        matching the web wall so both surfaces tell the same story }}
    <p>{{{t 'Become a paid member of {site} to get access to all premium content.' site=site.title}}}</p>
    {{/unless}}
    {{/if}}
        <table border="0" cellpadding="0" cellspacing="0">
            <tr>
                <td>
                    <table class="btn" border="0" cellspacing="0" cellpadding="0" align="center">
                        <tr>
                            <td align="center">
                                <a href="{{#if paywall.offerUrl}}{{paywall.offerUrl}}{{else}}{{paywall.signupUrl}}{{/if}}">{{#if paywall.buttonText}}{{paywall.buttonText}}{{else}}{{t 'Upgrade'}}{{/if}}</a>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    <p></p>
</div>