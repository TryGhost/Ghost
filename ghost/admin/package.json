  "name": "ghost-admin",
  "version": "6.53.1-rc.0",
  "description": "Ember.js admin client for Ghost",
  "author": "Ghost Foundation",
  "homepage": "http://ghost.org",
  "repository": {
    "type": "git",
    "url": "git://github.com/TryGhost/Admin.git"
