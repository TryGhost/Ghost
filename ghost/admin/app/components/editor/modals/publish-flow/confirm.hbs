<div class="gh-publish-title" data-test-publish-flow="confirm">
    <div class="green">Ready, set, publish.</div>
    <div>Share it with the world.</div>
</div>
<div class="gh-publish-confirmation" data-test-text="confirm-details">
    <p class="gh-publish-confirmation-intro">
        {{#if @publishOptions.isScheduled}}
            {{#let (moment-site-tz @publishOptions.scheduledAtUTC) as |scheduledAt|}}
                On <strong>{{moment-format scheduledAt "D MMM YYYY"}} at {{moment-format scheduledAt "HH:mm"}}</strong>, your {{this.postAccessDescription}} will be:
            {{/let}}
        {{else}}
            Your {{this.postAccessDescription}} will be:
        {{/if}}
    </p>

    <ul class="gh-publish-confirmation-list">
        {{#if this.willPublish}}
            <li>Published on your site.</li>
        {{/if}}

        {{#if this.willEmail}}
            {{#let (members-count-fetcher query=(hash filter=@publishOptions.fullRecipientFilter)) as |countFetcher|}}
                <li>
                    Emailed to
                    <strong>
                        {{if (eq @recipientType "all") "all"}}
                        {{format-number countFetcher.count}}
                        {{!-- @recipientType = none/free/paid/all/specific --}}
                        {{if (not-eq @recipientType "all") @recipientType}}
                        {{gh-pluralize countFetcher.count "subscriber" without-count=true}}
                    </strong>{{#unless @publishOptions.onlyDefaultNewsletter}}
                        of {{@publishOptions.newsletter.name~}}
                    {{/unless}}.
                </li>
            {{/let}}
        {{/if}}

        {{#unless this.willPublish}}
            <li><strong>Not</strong> published on your site.</li>
        {{/unless}}

        {{#if this.publicPreviewPaywallRecipientFilter}}
            {{#let (members-count-fetcher query=(hash filter=this.publicPreviewPaywallRecipientFilter)) as |countFetcher|}}
                {{#if countFetcher.count}}
                    <li data-test-public-preview-confirm-summary>
                        <strong>
                            {{format-number countFetcher.count}}
                            {{#if (eq @publishOptions.post.visibility "paid")}}
                                {{gh-pluralize countFetcher.count "free subscriber" without-count=true}}
                            {{else}}
                                {{gh-pluralize countFetcher.count "subscriber" without-count=true}} without access
                            {{/if}}
                        </strong>
                        {{#if (eq @publishOptions.post.visibility "paid")}}
                            of {{@publishOptions.newsletter.name}} will see a public preview and a paywall in their email.
                        {{else}}
                            will see a paywall in their email,
                            encouraging them to join an eligible tier.
                        {{/if}}
                    </li>

                    {{#if this.hasPublicPreviewWebPaywall}}
                        <li data-test-public-preview-confirm-web-summary>
                            Visitors without access will see the same public preview and paywall on your site.
                        </li>
                    {{/if}}
                {{else if this.hasPublicPreviewWebPaywall}}
                    <li data-test-public-preview-confirm-summary>
                        Visitors without access will see a paywall on your site,
                        {{#if (eq @publishOptions.post.visibility "paid")}}
                            encouraging them to become paid members.
                        {{else if (eq @publishOptions.post.visibility "tiers")}}
                            encouraging them to join an eligible tier.
                        {{else}}
                            encouraging them to become members.
                        {{/if}}
                    </li>
                {{/if}}
            {{/let}}
        {{else if this.hasPublicPreviewWebPaywall}}
            <li data-test-public-preview-confirm-summary>
                Visitors without access will see a paywall on your site,
                {{#if (eq @publishOptions.post.visibility "paid")}}
                    encouraging them to become paid members.
                {{else if (eq @publishOptions.post.visibility "tiers")}}
                    encouraging them to join an eligible tier.
                {{else}}
                    encouraging them to become members.
                {{/if}}
            </li>
        {{/if}}
    </ul>
</div>

{{#if this.errorMessage}}
    <p class="error gh-box gh-box-error mt3 mb3" data-test-confirm-error>
        {{this.errorMessage}}
    </p>
{{/if}}

<div class="gh-publish-cta">
    <GhTaskButton
        @task={{this.confirmTask}}
        @buttonText={{this.confirmButtonText}}
        @runningText={{this.confirmRunningText}}
        @successText={{this.confirmSuccessText}}
        @class="gh-btn gh-btn-large"
        @idleClass="gh-btn-pulse"
        @runningClass="gh-btn-green gh-btn-icon"
        @failureClass="gh-btn-red gh-btn-icon"
        data-test-button="confirm-publish"
    />
    <button type="button" class="gh-btn gh-btn-link gh-btn-large gh-publish-cta-secondary" {{on "click" @cancel}} data-test-button="back-to-options">Back to settings</button>
</div>
