<div class="gh-post-preview-modal">
    <header class="modal-header gh-post-preview-header" data-test-modal="preview-email">
        <div class="left">
            <h2>Preview</h2>
        </div>
        <div class="gh-post-preview-btn-group">
            <div class="gh-contentfilter gh-btn-group">
                <button type="button" class="gh-btn gh-post-preview-mode {{if (eq this.previewFormat "browser") "gh-btn-group-selected"}}" {{on "click" (fn this.changePreviewFormat "browser")}} data-test-button="browser-preview" data-test-selected={{eq this.previewFormat "browser"}}><span>Web</span></button>
                {{#if (and this.settings.membersEnabled (not-eq this.settings.editorDefaultEmailRecipients "disabled"))}}
                    {{#if (and @data.publishOptions.post.isPost (not @data.publishOptions.user.isContributor))}}
                        <button type="button" class="gh-btn {{if (eq this.previewFormat "email") "gh-btn-group-selected"}} gh-post-preview-mode" {{on "click" (fn this.changePreviewFormat "email")}} data-test-button="email-preview" data-test-selected={{eq this.previewFormat "email"}}><span>Email</span></button>
                    {{/if}}
                {{/if}}
            </div>
            <div class="gh-contentfilter-divider"></div>
            <div class="gh-contentfilter gh-btn-group gh-post-preview-sizes">
                <button type="button" class="gh-btn {{if (eq this.previewSize "desktop") "gh-btn-group-selected"}} gh-post-preview-mode" {{on "click" (fn this.changePreviewSize "desktop")}}><span>{{svg-jar "laptop"}}</span></button>
                <button type="button" class="gh-btn {{if (eq this.previewSize "mobile") "gh-btn-group-selected"}} gh-post-preview-mode" {{on "click" (fn this.changePreviewSize "mobile")}}><span>{{svg-jar "mobile-phone"}}</span></button>
            </div>
            {{#if this.showMemberSegmentDropdown}}
                <div class="gh-contentfilter-divider"></div>
                <span class="gh-select gh-web-preview-segment" data-test-select="preview-segment">
                    <PowerSelect
                        @selected={{this.selectedPreviewAsOption}}
                        @options={{this.previewAsOptions}}
                        @onChange={{this.changePreviewAsOption}}
                        @triggerComponent={{component "gh-power-select/trigger"}}
                        @triggerClass="gh-preview-segment-trigger"
                        @dropdownClass="gh-preview-segment-dropdown"
                        @matchTriggerWidth={{false}}
                        @onOpen={{this.dropdown.closeDropdowns}}
                        as |option|
                    >
                        {{option.label}}
                    </PowerSelect>
                </span>
            {{/if}}
        </div>
        <div class="right">
            <div class="gh-post-test-email-group">
                <GhDropdownButton
                    @dropdownName="post-preview-share"
                    @classNames="gh-btn gh-btn-preview gh-post-preview-url"
                    data-test-button="share-preview"
                >
                    <span>{{svg-jar "share"}}</span>
                </GhDropdownButton>
                <GhDropdown
                    @name="post-preview-share"
                    @classNames="dropdown-menu gh-post-preview-share-dropdown"
                    @onOpen={{this.focusInput}}
                >
                    <div class="gh-post-preview-share">
                        <GhTaskButton
                            @task={{this.copyPreviewUrlTask}}
                            @idleIcon="copy"
                            @buttonText="Copy preview link"
                            @runningText="Copy preview link"
                            @successText="Copied"
                            @successClass=""
                            @class="gh-btn gh-btn-icon gh-btn-preview gh-post-copy-url"
                            data-test-button="copy-draft-link"
                        />
                        <a href={{this.browserPreviewUrl}} target="_blank" rel="noopener noreferrer" class="gh-btn gh-btn-preview gh-publish-preview-newtab" data-test-link="open-draft">
                            <span>{{svg-jar "external"}}Open in new tab</span>
                        </a>
                    </div>
                </GhDropdown>
            </div>
            <div class="gh-contentfilter-divider"></div>
            <button
                type="button"
                class="gh-btn gh-btn-editor gh-editor-preview-trigger gh-post-preview-close active"
                {{on "click" @close}}
            >
                <span>Close</span>
            </button>

            {{#if @data.publishOptions.user.isContributor}}
                <GhTaskButton
                    @buttonText="Save"
                    @task={{@data.saveTask}}
                    @runningText="Saving"
                    @class="gh-btn gh-btn-icon gh-btn-editor gh-editor-save-trigger contributor-save-button"
                    data-test-preview-contributor-save />
            {{else}}
                <div class="gh-publish-trigger-wrap">
                    <button
                        type="button"
                        class="gh-btn gh-btn-primary"
                        {{on "click" this.publish}}
                    >
                        <span>Publish</span>
                    </button>

                    <div
                        class="gh-paid-post-paywall-prompt {{if this.isPaidPostPaywallPromptVisible "is-visible"}}"
                        role="dialog"
                        aria-modal="false"
                        aria-hidden={{not this.isPaidPostPaywallPromptVisible}}
                        aria-labelledby="preview-paid-post-paywall-prompt-title"
                        data-test-preview-paid-post-paywall-prompt
                    >
                        <div class="gh-paid-post-paywall-prompt-visual" aria-hidden="true">
                            <div class="gh-paid-post-paywall-prompt-post">
                                <div class="gh-paid-post-paywall-prompt-lines gh-paid-post-paywall-prompt-lines-top">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                                <div class="gh-paid-post-paywall-prompt-divider">
                                    <span class="gh-paid-post-paywall-prompt-divider-labels">
                                        <span class="gh-paid-post-paywall-prompt-divider-arrow">↓</span>
                                        <span>{{this.paywallPromptAccessLabel}}</span>
                                        <span class="gh-paid-post-paywall-prompt-divider-arrow">↓</span>
                                    </span>
                                </div>
                                <div class="gh-paid-post-paywall-prompt-lines gh-paid-post-paywall-prompt-lines-bottom">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                            </div>
                        </div>

                        <div class="gh-paid-post-paywall-prompt-content">
                            <div class="modal-header">
                                <h1 id="preview-paid-post-paywall-prompt-title">Add a public preview?</h1>
                            </div>

                            <div class="modal-body">
                                <p>This post is for paid members only — right now, everyone else sees none of it. A public preview lets them read the beginning free, up to the point you choose.</p>
                            </div>

                            <div class="gh-paid-post-paywall-prompt-actions">
                                <button type="button" class="gh-btn gh-btn-black gh-btn-fullwidth" {{on "click" (fn this.showPaywallGuidance @close)}}><span>Show me how</span></button>
                                <button type="button" class="gh-btn gh-btn-outline gh-btn-fullwidth" {{on "click" this.continueFromPaywallPrompt}}><span>Publish without it</span></button>
                            </div>
                        </div>
                    </div>
                </div>
            {{/if}}
        </div>
    </header>

    {{#if this.saveFirstTask.isRunning}}
        <GhLoadingSpinner />
    {{else}}
        {{#let @data.publishOptions.user.isContributor as |isContributor|}}
            {{#if (or isContributor (not @data.publishOptions.post.isPost) (eq this.previewFormat "browser"))}}
                <Editor::Modals::Preview::Browser
                    @previewUrl={{this.browserPreviewUrl}}
                    @skipAnimation={{this.skipAnimation}}
                    @mobile={{eq this.previewSize "mobile"}}
                    @closeModal={{@close}}
                />
            {{else}}
                <Editor::Modals::Preview::Email
                    @post={{@data.publishOptions.post}}
                    @memberSegment={{this.previewAsSegment}}
                    @newsletter={{@data.publishOptions.newsletter}}
                    @showMissingPaidPostPaywallWarning={{this.showMissingPaidPostPaywallWarning}}
                    @addPublicPreview={{fn @close (hash afterTask="showPublicPreviewGuidanceTask")}}
                    @skipAnimation={{this.skipAnimation}}
                    @savePostTask={{@data.saveTask}}
                    @mobile={{eq this.previewSize "mobile"}}
                    @closeModal={{@close}}
                />
            {{/if}}
        {{/let}}
    {{/if}}
</div>
