{
  "name": "@tryghost/parse-email-address",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/Ghost.git",
    "directory": "packages/parse-email-address"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "pnpm build:tsc",
    "build:tsc": "tsc",
    "test:unit": "NODE_ENV=testing vitest run --coverage",
    "test:types": "tsc --noEmit",
    "test": "pnpm run '/^test:/'",
    "lint:code": "eslint src/ --cache",
    "lint:test": "eslint test/ --cache",
    "lint": "pnpm run '/^lint:/'"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@internal/cfg-eslint": "workspace:*",
    "@internal/cfg-typescript": "workspace:*",
    "@internal/cfg-vitest": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "@typescript/native": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "parse-email-address": "0.0.2"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": ["{projectRoot}/build"]
      }
    }
  }
}
