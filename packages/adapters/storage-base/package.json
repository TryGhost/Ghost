{
  "name": "ghost-storage-base",
  "version": "2.1.5",
  "description": "Base class for Ghost storage adapters.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/Ghost.git",
    "directory": "packages/adapters/storage-base"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "keywords": [
    "ghost",
    "storage",
    "adapter"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test:unit": "NODE_ENV=testing vitest run --coverage",
    "test": "pnpm run '/^test:/'",
    "test:types": "tsc --noEmit -p test/tsconfig.json",
    "lint:code": "eslint src/ --cache",
    "lint:test": "eslint test/ --cache",
    "lint": "pnpm run '/^lint:/'"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "moment": "catalog:"
  },
  "devDependencies": {
    "@internal/cfg-eslint": "workspace:*",
    "@internal/cfg-typescript": "workspace:*",
    "@internal/cfg-vitest": "workspace:*",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "@typescript/native": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/build"
        ]
      }
    }
  }
}
