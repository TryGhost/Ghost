{
  "name": "@tryghost/i18n",
  "version": "0.0.0",
  "repository": "https://github.com/TryGhost/Ghost/tree/main/packages/i18n",
  "author": "Ghost Foundation",
  "private": true,
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./registry/*": {
      "types": "./registry.d.ts",
      "default": "./lib/registry/*.mjs"
    },
    "./lib/locale-data.json": "./lib/locale-data.json",
    "./package.json": "./package.json"
  },
  "types": "./index.d.ts",
  "scripts": {
    "test:base": "NODE_ENV=testing vitest run --coverage",
    "test": "pnpm test:base && pnpm translate",
    "lint:code": "eslint *.js *.mjs lib/ --cache",
    "lint": "pnpm run '/^lint:/'",
    "lint:test": "eslint test/ --cache",
    "lint:translations": "node ./test/i18n.lint.js",
    "translate": "pnpm translate:ghost && pnpm translate:portal && pnpm translate:signup-form && pnpm translate:comments && pnpm translate:search && node generate-context.js",
    "translate:ghost": "NAMESPACE=ghost i18next '../../ghost/core/core/{frontend,server,shared}/**/*.{js,jsx,ts}' '!../../ghost/core/core/frontend/public/*.min.js' '../../ghost/core/core/server/services/email-rendering/partials/**/*.hbs' '../../ghost/core/core/server/services/email-service/email-templates/**/*.hbs' '../../ghost/core/core/server/services/comments/email-templates/**/*.hbs' '../../ghost/core/core/server/services/member-welcome-emails/email-templates/**/*.hbs' '../../ghost/core/core/server/services/gifts/**/*.{ts,hbs}'",
    "translate:portal": "NAMESPACE=portal i18next '../../apps/portal/src/**/*.{js,jsx}'",
    "translate:signup-form": "NAMESPACE=signup-form i18next '../../apps/signup-form/src/**/*.{ts,tsx}'",
    "translate:comments": "NAMESPACE=comments i18next '../../apps/comments-ui/src/**/*.{ts,tsx}'",
    "translate:search": "NAMESPACE=search i18next '../../apps/sodo-search/src/**/*.{js,jsx,ts,tsx}'"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "registry.d.ts",
    "lib",
    "locales"
  ],
  "devDependencies": {
    "@internal/cfg-eslint": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "fs-extra": "catalog:",
    "glob": "catalog:",
    "i18next-parser": "9.4.0",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@tryghost/debug": "catalog:",
    "i18next": "23.16.8"
  },
  "nx": {
    "tags": [
      "i18n"
    ]
  }
}
