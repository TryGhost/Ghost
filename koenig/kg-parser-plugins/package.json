{
  "name": "@tryghost/kg-parser-plugins",
  "version": "4.2.25",
  "repository": "https://github.com/TryGhost/Koenig/tree/main/packages/kg-parser-plugins",
  "author": "Ghost Foundation",
  "license": "MIT",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.js",
  "types": "build/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/esm/index.d.ts",
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "build"
  ],
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput",
    "build": "tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > build/esm/package.json",
    "prepare": "tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > build/esm/package.json",
    "pretest": "tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > build/esm/package.json && tsc -p tsconfig.test.json",
    "test": "NODE_ENV=testing c8 --all --reporter text --reporter cobertura mocha --require tsx './test/**/*.test.ts'",
    "lint": "eslint . --cache",
    "posttest": "yarn lint"
  },
  "engines": {
    "node": "^22.13.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tryghost/mobiledoc-kit": "0.11.2-ghost.4",
    "@types/mocha": "10.0.10",
    "@types/node": "24.12.0",
    "@types/should": "13.0.0",
    "@types/sinon": "21.0.0",
    "c8": "11.0.0",
    "jsdom": "29.0.1",
    "mocha": "11.7.5",
    "should": "13.2.3",
    "sinon": "21.0.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  },
  "dependencies": {
    "@tryghost/kg-clean-basic-html": "*"
  }
}
