    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "10.5.0",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-tailwindcss": "3.18.3",
