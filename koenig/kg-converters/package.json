{
  "name": "@tryghost/kg-converters",
  "version": "1.2.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/Ghost.git",
    "directory": "koenig/kg-converters"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.js",
  "types": "build/esm/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./build/esm/index.d.ts",
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput",
    "build": "tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > build/esm/package.json",
    "pretest": "tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > build/esm/package.json && tsc -p tsconfig.test.json",
    "test:unit": "NODE_ENV=testing c8 --all --src src/ --check-coverage --reporter text --reporter cobertura mocha --require tsx './test/**/*.test.ts'",
    "test": "pnpm test:unit",
    "posttest": "pnpm lint",
    "lint": "eslint . --cache"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/mocha": "10.0.10",
    "@types/node": "catalog:",
    "c8": "catalog:",
    "mocha": "11.7.6",
    "sinon": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "dependencies": {
    "lodash": "catalog:"
  }
}
