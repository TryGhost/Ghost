{
  "name": "@tryghost/koenig-lexical",
  "version": "1.8.3",
  "repository": "https://github.com/TryGhost/Koenig/tree/master/packages/koenig-lexical",
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "files": [
    "LICENSE",
    "README.md",
    "dist/"
  ],
  "main": "./dist/koenig-lexical.umd.js",
  "module": "./dist/koenig-lexical.js",
  "exports": {
    ".": {
      "import": "./dist/koenig-lexical.js",
      "require": "./dist/koenig-lexical.umd.js"
    }
  },
  "scripts": {
    "dev": "concurrently \"vite --host --force\" \"pnpm build --watch\" \"pnpm preview -l silent --host\" \"pnpm --filter @tryghost/kg-default-nodes dev\" \"pnpm --filter @tryghost/kg-default-transforms dev\"",
    "dev:integrated": "concurrently \"pnpm build --watch\" \"pnpm preview -l silent --host\" \"pnpm --filter @tryghost/kg-default-nodes dev\" \"pnpm --filter @tryghost/kg-default-transforms dev\"",
    "dev:multiplayer": "concurrently \"vite\" \"pnpm multiplayer\"",
    "dev:test": "concurrently \"vite --port 5174\" \"pnpm multiplayer\"",
    "multiplayer": "HOST=localhost PORT=1234 npx y-websocket-server",
    "build": "vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "preview": "vite preview",
    "pretest": "VITE_TEST=true pnpm build --config vite.config.demo.ts && pnpm build",
    "test": "pnpm test:unit && pnpm test:acceptance",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:acceptance": "NODE_ENV=test PLAYWRIGHT_FORCE_ASYNC_LOADER=1 NODE_OPTIONS='--experimental-specifier-resolution=node --no-warnings' VITE_TEST=true playwright test",
    "test:acceptance:headed": "PLAYWRIGHT_HEADED=true pnpm test:acceptance",
    "test:acceptance:report": "PLAYWRIGHT_HTML_REPORT=true pnpm test:acceptance",
    "test:acceptance:quiet": "pnpm test:acceptance --reporter=line",
    "test:slowmo": "TIMEOUT=100000 PLAYWRIGHT_SLOWMO=100 pnpm test:acceptance:headed",
    "pretest:watch": "pnpm pretest",
    "posttest": "pnpm lint",
    "coverage": "vitest run --coverage",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:js": "eslint --cache demo src test",
    "storybook": "NODE_OPTIONS=--openssl-legacy-provider storybook dev -p 6006 -h 127.0.0.1",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/plugin-proposal-private-property-in-object": "7.21.11",
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/commands": "6.10.3",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/language": "6.12.3",
    "@codemirror/view": "6.43.1",
    "@emoji-mart/data": "1.2.1",
    "@emoji-mart/react": "1.1.1",
    "@etchteam/storybook-addon-status": "8.1.0",
    "@lexical/clipboard": "0.13.1",
    "@lexical/headless": "0.13.1",
    "@lexical/html": "0.13.1",
    "@lexical/link": "0.13.1",
    "@lexical/list": "0.13.1",
    "@lexical/markdown": "0.13.1",
    "@lexical/react": "0.13.1",
    "@lexical/rich-text": "0.13.1",
    "@lexical/selection": "0.13.1",
    "@lexical/text": "0.13.1",
    "@lexical/utils": "0.13.1",
    "@lezer/highlight": "1.2.3",
    "@mdx-js/rollup": "3.1.1",
    "@playwright/test": "1.61.1",
    "@prettier/sync": "0.6.1",
    "@sentry/vite-plugin": "5.3.0",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@tryghost/color-utils": "0.2.19",
    "@tryghost/helpers": "1.1.106",
    "@tryghost/kg-clean-basic-html": "workspace:~",
    "@tryghost/kg-converters": "workspace:~",
    "@tryghost/kg-default-nodes": "workspace:~",
    "@tryghost/kg-default-transforms": "workspace:~",
    "@tryghost/kg-markdown-html-renderer": "workspace:~",
    "@tryghost/kg-simplemde": "workspace:~",
    "@tryghost/kg-unsplash-selector": "workspace:~",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@uiw/codemirror-extensions-basic-setup": "4.25.10",
    "@uiw/react-codemirror": "4.25.10",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-c8": "0.33.0",
    "@vitest/ui": "4.1.9",
    "autoprefixer": "10.5.2",
    "babel-loader": "10.1.1",
    "clsx": "2.1.1",
    "codemirror": "6.0.2",
    "concurrently": "10.0.3",
    "cross-fetch": "4.1.0",
    "dompurify": "3.4.11",
    "dotenv": "17.4.2",
    "emoji-mart": "5.6.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-storybook": "10.4.6",
    "eslint-plugin-tailwindcss": "3.18.3",
    "eventemitter3": "5.0.4",
    "fast-average-color": "9.5.2",
    "fs-extra": "catalog:",
    "highlight.js": "10.7.3",
    "jsdom": "29.1.1",
    "lexical": "0.13.1",
    "lodash": "catalog:",
    "pluralize": "8.0.0",
    "postcss": "8.5.15",
    "postcss-import": "16.1.1",
    "prettier": "3.9.4",
    "prettier-plugin-organize-attributes": "1.0.0",
    "prop-types": "15.8.1",
    "react": "18.3.1",
    "react-colorful": "5.7.0",
    "react-dom": "18.3.1",
    "react-error-boundary": "3.1.4",
    "react-highlight": "0.15.0",
    "react-router-dom": "7.18.1",
    "react-slider": "2.0.6",
    "storybook": "10.4.6",
    "stylelint": "17.14.0",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.9",
    "y-websocket": "3.0.0",
    "yjs": "13.6.31"
  },
  "nx": {
    "tags": [
      "playwright"
    ],
    "targets": {
      "build:demo": {
        "dependsOn": [
          "^build"
        ]
      },
      "dev:integrated": {
        "continuous": true,
        "dependsOn": [
          "^build"
        ]
      },
      "test:acceptance": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}
