{
  "name": "@tryghost/kg-default-nodes",
  "version": "2.1.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/Ghost.git",
    "directory": "koenig/kg-default-nodes"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "engines": {
    "node": "^22.13.1 || ^24.0.0"
  },
  "main": "build/cjs/index.js",
  "module": "build/esm/index.js",
  "types": "build/esm/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./build/esm/index.d.ts",
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js"
    },
    "./visibility": {
      "source": "./src/visibility.ts",
      "types": "./build/esm/visibility.d.ts",
      "import": "./build/esm/visibility.js",
      "require": "./build/cjs/visibility.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf build",
    "build": "pnpm clean && tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > build/esm/package.json",
    "test:unit": "NODE_ENV=testing vitest run --coverage",
    "test:types": "tsc --noEmit",
    "test": "pnpm test:types && pnpm test:unit",
    "lint:code": "eslint src/ --cache",
    "lint": "pnpm lint:code && pnpm lint:test",
    "lint:test": "eslint test/ --cache"
  },
  "files": [
    "LICENSE",
    "README.md",
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@lexical/headless": "0.13.1",
    "@lexical/html": "0.13.1",
    "@prettier/sync": "0.6.1",
    "@types/jsdom": "catalog:",
    "@types/lodash": "4.17.24",
    "@types/luxon": "3.7.2",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "html-minifier": "4.0.0",
    "prettier": "3.9.4",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@lexical/clipboard": "0.13.1",
    "@lexical/rich-text": "0.13.1",
    "@lexical/selection": "0.13.1",
    "@lexical/utils": "0.13.1",
    "@tryghost/color-utils": "catalog:",
    "@tryghost/kg-clean-basic-html": "workspace:~",
    "@tryghost/kg-markdown-html-renderer": "workspace:~",
    "clsx": "catalog:",
    "entities": "catalog:",
    "html-minifier": "4.0.0",
    "jsdom": "catalog:",
    "lexical": "0.13.1",
    "lodash": "catalog:",
    "luxon": "3.7.2"
  }
}
