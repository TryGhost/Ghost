{
  "name": "@tryghost/kg-card-factory",
  "version": "5.2.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/Ghost.git",
    "directory": "koenig/kg-card-factory"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.js",
  "types": "build/esm/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./build/esm/index.d.ts",
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js"
    }
  },
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build": "tsc && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > build/esm/package.json",
    "test": "pnpm test:types && pnpm test:unit",
    "test:unit": "NODE_ENV=testing vitest run --coverage",
    "test:types": "tsc -p tsconfig.test.json",
    "lint": "eslint . --cache",
    "posttest": "pnpm lint"
  },
  "engines": {
    "node": "^22.13.1 || ^24.0.0"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@types/should": "13.0.0",
    "@types/sinon": "21.0.1",
    "@vitest/coverage-v8": "catalog:",
    "should": "13.2.3",
    "simple-dom": "1.4.0",
    "sinon": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
