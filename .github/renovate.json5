{
    extends: [
        'github>tryghost/renovate-config',
    ],
    branchConcurrentLimit: 10,
    recreateWhen: 'auto',
    platformAutomerge: false,
    timezone: 'Etc/UTC',
    automergeSchedule: [
        '* * * * 0,6',
        '* 0-12 * * 1',
    ],
    ignoreDeps: [
        'got',
        'intl-messageformat',
        'moment',
        'moment-timezone',
        'simple-dom',
        'ember-drag-drop',
        'normalize.css',
        'validator',
        '@embroider/macros',
        'codemirror',
        'ember-cli-code-coverage',
        'ember-cli-terser',
    ],
    ignorePaths: [
        'test',
        'ghost/admin/lib/koenig-editor/package.json',
    ],
    packageRules: [
        {
            description: 'Require dashboard approval for major updates',
            matchUpdateTypes: [
                'major',
            ],
            dependencyDashboardApproval: true,
        },
        {
            groupName: 'NQL packages',
            matchPackageNames: [
                '@tryghost/nql',
                '@tryghost/nql-lang',
            ],
        },
        {
            matchPackageNames: [
                'lucide-react',
            ],
            automerge: true,
        },
        {
            groupName: 'Disable ember updates',
            matchFileNames: [
                'ghost/admin/package.json',
            ],
            matchPackageNames: [
                '/^ember(-|$)/',
                '/^@ember\\//',
                '/\\/ember(-|$)/',
            ],
            enabled: false,
        },
        {
            groupName: 'disable css',
            matchFileNames: [
                'ghost/admin/package.json',
            ],
            matchPackageNames: [
                'autoprefixer',
                'ember-cli-postcss',
                '/^postcss/',
                '/^css/',
            ],
            enabled: false,
        },
    ],
}
